# Пример переменных окружения для Stalwart Mail Server.
# Для локального запуска скопируйте файл в .env и отредактируйте.
# В Portainer переменные можно задать в UI при создании Stack.

# IP-адрес вашего сервера (используется в README и конфиге Nginx)
SERVER_IP=203.0.113.10

# Почтовый hostname сервера — должен быть доменом, который резолвится на IP.
# Для теста можно использовать любой из ваших доменов, например mail.example.com.
STALWART_HOSTNAME=mail.example.com

# Версия/тег образа Stalwart. Рекомендуется фиксировать минорную версию.
STALWART_IMAGE=stalwartlabs/stalwart:v0.16

# Имя контейнера
STALWART_CONTAINER_NAME=stalwart-mail

# Recovery-админ. Формат: имя:пароль. Обязательно смените пароль!
STALWART_RECOVERY_ADMIN=admin:ChangeMeStrongPassword123

# Публичный URL, который Stalwart будет сообщать клиентам (JMAP, OAuth и пр.).
# Если ваш Nginx раздает HTTPS по IP сервера:
STALWART_PUBLIC_URL=https://203.0.113.10/
# Если обходитесь без Nginx (не рекомендуется):
# STALWART_PUBLIC_URL=http://203.0.113.10:8080/

# На каком IP биндить веб-админку (8080). По умолчанию только localhost.
# Если Nginx работает на этом же сервере — оставьте 127.0.0.1.
# Если Nginx на другом хосте — укажите 0.0.0.0 или конкретный IP сервера.
ADMIN_BIND_IP=127.0.0.1

# Часовой пояс
TZ=Europe/Moscow
