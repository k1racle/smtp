# Mailu основная конфигурация
# Отредактируйте DOMAIN, HOSTNAMES, SECRET_KEY, INITIAL_ADMIN_PW перед деплоем.

MAILU_VERSION=2024.06

# Случайный 16-байтовый ключ. Сгенерируйте свой: openssl rand -hex 16
SECRET_KEY=ec88cc5fce4b4a7f01dfcb0b5733908c

# Подсеть внутренней Docker-сети. Не должна пересекаться с другими сетями сервера.
SUBNET=192.168.203.0/24

# Основной почтовый домен
DOMAIN=winemaking-today.ru

# Hostname сервера (через запятую можно указать несколько). Должен резолвиться в IP сервера.
HOSTNAMES=mail.winemaking-today.ru

# Postmaster (будет создан ящик postmaster@DOMAIN)
POSTMASTER=admin

# Тип TLS.
# mail  — Mailu использует предоставленный сертификат для почтовых портов (SMTP/IMAP/POP3).
#         HTTP-порт остаётся plain, чтобы за ним стоял ваш Nginx Proxy Manager.
TLS_FLAVOR=mail

# Лимиты на авторизацию
AUTH_RATELIMIT_IP=60/hour
AUTH_RATELIMIT_USER=200/day

# Отключить отправку статистики
DISABLE_STATISTICS=True

# Включить админку
ADMIN=true

# Автоматическое создание администратора
INITIAL_ADMIN_ACCOUNT=admin
INITIAL_ADMIN_DOMAIN=winemaking-today.ru
INITIAL_ADMIN_PW=ChangeMeStrongPassword123
INITIAL_ADMIN_MODE=update

# Webmail: roundcube (поддерживает русский)
WEBMAIL=roundcube

# CalDAV/CardDAV — отключено
WEBDAV=none

# Антивирус — отключено (ClamAV требует много памяти)
ANTIVIRUS=none

# Сканирование макросов вложений
SCAN_MACROS=false

# Лимит размера письма (в байтах). 50 MB.
MESSAGE_SIZE_LIMIT=50000000

# Лимит исходящих писем на пользователя
MESSAGE_RATELIMIT=1000/day

# Разделитель для псевдонимов/подпапок (user+tag@domain)
RECIPIENT_DELIMITER=+

# DMARC отчёты
DMARC_RUA=admin
DMARC_RUF=admin

# Приветственное письмо новым ящикам
WELCOME=false

# Пути веб-интерфейса
WEBROOT_REDIRECT=/webmail
WEB_ADMIN=/admin
WEB_WEBMAIL=/webmail

# Название сайта
SITENAME=Mail Server
WEBSITE=https://mail.winemaking-today.ru

# Настройки для работы за Nginx Proxy Manager
REAL_IP_HEADER=X-Real-IP
REAL_IP_FROM=0.0.0.0/0,::

# Часовой пояс
TZ=Europe/Moscow

# Уровень логирования
LOG_LEVEL=WARNING

# Проект Docker Compose
COMPOSE_PROJECT_NAME=mailu

# На каком IP/порту биндить веб-интерфейс Mailu (для проксирования NPM)
MAILU_WEB_BIND=0.0.0.0
MAILU_WEB_PORT=8880
